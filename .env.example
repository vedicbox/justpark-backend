# ─────────────────────────────────────────────────────────────
# JustPark Backend — Example Environment Variables
# Copy this file to .env and replace all placeholder values
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NODE_ENV=development # App environment: development | production | test
PORT=3000 # Port the backend API listens on inside the container
BACKEND_DOCKER_PORT=5000 # Host port for the Docker backend container to avoid conflict with local backend on 3000
API_VERSION=v1 # API version prefix used in routes, e.g. /api/v1
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3002 # Allowed frontend origins for CORS

# ─────────────────────────────────────────────
# Database — PostgreSQL + PostGIS
# ─────────────────────────────────────────────
POSTGRES_USER=your_postgres_user_here # Local or Docker Postgres username
POSTGRES_PASSWORD=your_postgres_password_here # Local or Docker Postgres password
POSTGRES_DB=your_postgres_database_here # Primary Postgres database name
POSTGRES_HOST=localhost # Postgres host for local development
POSTGRES_PORT=5432 # Postgres port for local development
DATABASE_URL=postgresql://your_postgres_user_here:your_postgres_password_here@localhost:5432/your_postgres_database_here?schema=public # Prisma database connection string

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=localhost # Redis host for local development
REDIS_PORT=6379 # Redis port for local development
REDIS_PASSWORD=your_redis_password_here # Redis password, if enabled
REDIS_DB=0 # Redis logical database index
REDIS_URL=redis://:your_redis_password_here@localhost:6379 # Redis connection string used by the app

# ─────────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=your_jwt_access_secret_here_at_least_32_chars # Secret used to sign access tokens
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_at_least_32_chars # Secret used to sign refresh tokens
JWT_ACCESS_EXPIRES_IN=15m # Access token lifetime
JWT_REFRESH_EXPIRES_IN=30d # Refresh token lifetime

# ─────────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────────
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa # 64-char hex key for sensitive data encryption

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000 # Global rate-limit window in milliseconds
RATE_LIMIT_MAX_REQUESTS=100 # Max requests per window for general API traffic
RATE_LIMIT_AUTH_MAX=5 # Max auth requests per window per client

# ─────────────────────────────────────────────
# File Upload — Cloudinary
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here # Cloudinary cloud name
CLOUDINARY_API_KEY=your_cloudinary_api_key_here       # Cloudinary API key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here # Cloudinary API secret

# ─────────────────────────────────────────────
# Stripe
# ─────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here # Stripe server-side secret key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here # Stripe frontend publishable key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here # Stripe webhook signing secret

# ─────────────────────────────────────────────
# Razorpay — Payment Gateway
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id_here # Razorpay public key for payments
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here # Razorpay secret key for payments
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here # Razorpay webhook signing secret

# Razorpay X — Payout API
RAZORPAY_X_KEY_ID=your_razorpay_x_key_id_here # Razorpay X key ID for payouts
RAZORPAY_X_KEY_SECRET=your_razorpay_x_key_secret_here # Razorpay X key secret for payouts
RAZORPAY_X_ACCOUNT_NUMBER=your_razorpay_x_account_number_here # Source account number used for payouts
RAZORPAY_X_WEBHOOK_SECRET=your_razorpay_x_webhook_secret_here # Razorpay X webhook signing secret

# ─────────────────────────────────────────────
# Email — Brevo
# ─────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here # Brevo API key for transactional email
EMAIL_FROM=noreply@example.com # Default sender email address
EMAIL_FROM_NAME=Your App Name Here # Default sender display name

SUPPORT_SMTP_HOST=smtp.hostinger.com # Support mailbox SMTP host
SUPPORT_SMTP_PORT=587 # Support mailbox SMTP port (STARTTLS)
SUPPORT_SMTP_SECURE=false # false for STARTTLS on port 587
SUPPORT_SMTP_USER=support@example.com # Support mailbox username
SUPPORT_SMTP_PASS=your_support_mailbox_password_here # Support mailbox password
SUPPORT_EMAIL_FROM=support@example.com # Support mailbox sender
SUPPORT_EMAIL_FROM_NAME=Your Support Team # Support mailbox display name

# ─────────────────────────────────────────────
# SMS — Twilio
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here # Twilio account SID for SMS
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here # Twilio auth token for SMS
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here # Twilio sending phone number

# ─────────────────────────────────────────────
# Firebase Admin / FCM
# ─────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id_here # Firebase project ID for Admin SDK
FIREBASE_PRIVATE_KEY=your_firebase_private_key_here # Firebase Admin private key (set this as a secret in Railway)
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here # Firebase Admin client email
FCM_PROJECT_ID=your_fcm_project_id_here # Backward-compatible Firebase project ID for push
FCM_PRIVATE_KEY=your_fcm_private_key_here # Backward-compatible Firebase private key (set this as a secret in Railway)
FCM_CLIENT_EMAIL=your_fcm_client_email_here # Backward-compatible Firebase client email

# ─────────────────────────────────────────────
# Google / Apple Integrations
# ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here # Google Maps / Places API key
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here # Google OAuth client ID for social login
APPLE_APP_BUNDLE_ID=your_apple_app_bundle_id_here # Apple bundle ID for Sign in with Apple

# ─────────────────────────────────────────────
# Business Logic
# ─────────────────────────────────────────────
PLATFORM_COMMISSION_RATE=0.15 # Platform commission rate charged on bookings
TAX_RATE=0.18 # Tax rate used in pricing calculations
SLOT_LOCK_TTL_SECONDS=600 # Booking slot lock TTL in seconds
DISPUTE_WINDOW_HOURS=72 # Hours before earnings become available after a booking
OTP_EXPIRY_MINUTES=10 # Expiry time for custom email/password-reset OTPs
MAX_SESSIONS_PER_USER=5 # Maximum concurrent active sessions per user

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info # Log verbosity: fatal | error | warn | info | debug | trace
LOG_PRETTY=true # Pretty-print logs in local development

# ─────────────────────────────────────────────
# Additional Local/Infra Helpers
# These are used elsewhere in the project but are not validated in env.ts.
# ─────────────────────────────────────────────
BULLMQ_REDIS_URL=redis://:your_redis_password_here@localhost:6379 # Redis URL for BullMQ worker helpers
JOB_CONCURRENCY=5 # Default BullMQ worker concurrency
SOCKET_CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:5173 # Allowed Socket.IO origins
